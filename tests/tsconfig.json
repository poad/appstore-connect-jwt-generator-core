{
  "compilerOptions": {
    "target": "esnext",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "rootDirs": ["."],
    "declaration": true,
    "declarationMap": false,
    "sourceMap": false,
    "outDir": "./esm",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "types": ["node"]
  },
  "exclude": [
    "node_modules",
    "./esm",
    "**/*.test.ts",
    "tests",
    "vitest.config.ts"
  ]
}
